{
  "name": "trg-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node ./scripts/check-seo-baseline.mjs && node ./scripts/check-blog-chrome.mjs && node ./scripts/audit-headings.mjs && node ./scripts/check-blog-uniqueness.mjs && node ./scripts/blog-opposing-review.mjs && node ./scripts/check-blog-quality.mjs && node ./scripts/check-geo-lite.mjs && node ./scripts/check-brand-alignment.mjs",
    "blog:inventory": "node ./scripts/blog-inventory.mjs",
    "blog:open-slot": "node ./scripts/blog-open-slot.mjs",
    "blog:opposing-review": "node ./scripts/blog-opposing-review.mjs",
    "seo:sync-mystic": "node ./scripts/sync-mystic-seo-report.mjs",
    "seo:guidelines:init": "node ./scripts/seo-init-guideline-baseline.mjs",
    "seo:guidelines:check": "node ./scripts/seo-check-guideline-baseline.mjs",
    "audit-headings": "node ./scripts/audit-headings.mjs",
    "seo:snapshot": "node ./scripts/extract-pre-migration-seo-snapshot.mjs",
    "seo:sitemap:diff": "node ./scripts/diff-sitemap-urls.mjs",
    "seo:sitemap:baseline": "node ./scripts/diff-sitemap-urls.mjs --write-baseline",
    "seo:redirects:verify": "node ./scripts/verify-redirects.mjs",
    "seo:redirects:verify:live": "node ./scripts/verify-redirects.mjs --live",
    "seo:phase0": "node ./scripts/extract-pre-migration-seo-snapshot.mjs && node ./scripts/diff-sitemap-urls.mjs && node ./scripts/verify-redirects.mjs",
    "tally:patch": "node ./scripts/patch-trg-tally-forms.mjs",
    "resources:pdfs": "python3 scripts/generate-lead-magnet-pdfs.py",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/dm-serif-display": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.4",
    "gray-matter": "^4.0.3",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19"
  }
}
