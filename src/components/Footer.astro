---
import SiteLogo from './SiteLogo.astro';
import {
  footerContact,
  footerLocations,
  footerResources,
  footerServices,
  ctaNav,
} from '../data/navigation';
---

<footer class="border-t border-white/10 bg-[#1C1C1C] text-white">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <h2 class="sr-only">Site footer</h2>

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-8">
      <div class="lg:col-span-4">
        <a href="/" class="inline-flex no-underline" aria-label="Toronto Restaurant Growth home">
          <SiteLogo variant="horizontalLight" loading="lazy" />
        </a>
        <p class="mt-6 max-w-sm text-sm leading-relaxed text-white/65">
          Website development, Google visibility, and review systems for independent Toronto restaurants. One plan. One focus. Restaurants only.
        </p>
        <p class="mt-4 font-heading text-base italic text-[#E85D04]">
          We only work with restaurants.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:col-span-8">
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-white/90">Services</h3>
          <ul class="mt-4 space-y-2.5">
            {footerServices.map((item) => (
              <li>
                <a href={item.href} class="text-sm text-white/60 no-underline transition-colors hover:text-white">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-white/90">Locations</h3>
          <ul class="mt-4 space-y-2.5">
            {footerLocations.map((item) => (
              <li>
                <a href={item.href} class="text-sm text-white/60 no-underline transition-colors hover:text-white">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-white/90">Company</h3>
          <ul class="mt-4 space-y-2.5">
            {footerResources.map((item) => (
              <li>
                <a href={item.href} class="text-sm text-white/60 no-underline transition-colors hover:text-white">
                  {item.label}
                </a>
              </li>
            ))}
            {footerContact.map((item) => (
              <li>
                <a href={item.href} class="text-sm text-white/60 no-underline transition-colors hover:text-white">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
          <a href={ctaNav.href} class="btn-cta mt-6 text-sm">
            {ctaNav.label}
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-white/10 pt-8 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="font-heading text-white">&copy; {new Date().getFullYear()} Toronto Restaurant Growth</p>
        <div class="mt-2 flex flex-wrap gap-x-5 gap-y-1 text-xs text-white/50">
          <a href="/privacy/" class="no-underline hover:text-white">Privacy Policy</a>
          <a href="/terms/" class="no-underline hover:text-white">Terms of Use</a>
        </div>
      </div>
      <p class="text-xs text-white/50">Built for Toronto's independent restaurant community.</p>
    </div>
  </div>
</footer>
