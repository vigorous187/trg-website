---
interface Metric {
  value: string;
  label: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---

<div class="grid grid-cols-2 border-y border-white/20 bg-accent sm:grid-cols-3 lg:grid-cols-5">
  {metrics.map((metric, i) => (
    <div
      class={`px-4 py-8 text-center sm:px-6 ${i < metrics.length - 1 ? 'border-b border-white/20 sm:border-b-0 sm:border-r' : ''}`}
    >
      <p class="font-heading text-3xl leading-none text-white sm:text-4xl">{metric.value}</p>
      <p class="mt-2 text-xs font-medium uppercase tracking-wider text-white/85">{metric.label}</p>
    </div>
  ))}
</div>
