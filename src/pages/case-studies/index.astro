---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClientLogo from '../../components/ClientLogo.astro';
import PageIntro from '../../components/PageIntro.astro';
import PageCta from '../../components/PageCta.astro';

const caseStudies = [
  {
    client: "Crab Boil",
    logo: "crabBoil" as const,
    category: "Social Media & Growth",
    headline: "500 Million Impressions. Zero Traditional Ad Spend.",
    description: "From zero digital presence to 113K TikTok followers, 89K Instagram followers, and a successful Ottawa expansion. The most-followed restaurant brand TRG has built.",
    metrics: [
      { value: "500M+", label: "Combined Impressions" },
      { value: "113K", label: "TikTok Followers" },
      { value: "$2K→$4K", label: "Monthly Retainer Growth" },
    ],
    href: "/case-studies/crab-boil/",
    status: "live",
  },
  {
    client: "Mystic Caribbean",
    logo: "mystic" as const,
    category: "Google Maps & SEO",
    headline: "#1 on Kennedy Road. 15 Keywords in the Top 10.",
    description: "From a 32/100 SpotHopper template to dominant local search in Brampton — with a live SEO dashboard TRG uses to prove ROI.",
    metrics: [
      { value: "#1", label: "Kennedy Rd Restaurant" },
      { value: "73/100", label: "SEO Score" },
      { value: "15", label: "Keywords Top 10" },
    ],
    href: "/case-studies/mystic-caribbean/",
    status: "live",
  },
];
---

<BaseLayout
  title="Restaurant Marketing Case Studies Toronto | TRG"
  description="Real results for real Toronto restaurants. See how TRG has grown restaurant brands through Google Maps SEO, social media, and review management."
>
  <main>
    <PageIntro
      title="Real Numbers. Real Restaurants."
      description="These aren't agency-inflated impressions — they're the work of a restaurant marketing agency Toronto operators hire when they want measurable growth. See social reach with Crab Boil and Google Maps SEO wins with Mystic Caribbean, with the receipts to prove it."
      ctaLabel="Book a Free Google Audit"
      ctaHref="/contact/"
    />

    <section class="bg-surface py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        {caseStudies.map((study) => (
          <a href={study.href} class="trg-link-card">
            <div class="trg-link-card-header">
              <div>
                <ClientLogo client={study.logo} size="lg" />
                <p class="mt-3 text-xs font-semibold uppercase tracking-widest text-ink-muted">{study.category}</p>
              </div>
            </div>
            <div class="trg-link-card-body trg-prose">
              <h2>{study.headline}</h2>
              <p>{study.description}</p>
              <div class="mt-6 flex flex-wrap gap-8 border-t border-stone-border pt-6">
                {study.metrics.map((m) => (
                  <div>
                    <p class="font-heading text-3xl text-accent">{m.value}</p>
                    <p class="text-xs text-ink-muted">{m.label}</p>
                  </div>
                ))}
              </div>
              <span class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-cta">
                Read full case study
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </div>
          </a>
        ))}

      </div>
    </section>

    <PageCta
      title="Want results like these for your restaurant?"
      description="Every engagement starts with a free Google audit. We'll show you exactly where you stand and what it would take to get results like the ones above."
    />
  </main>
</BaseLayout>
