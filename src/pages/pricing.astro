---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/PageIntro.astro';
import { growthPlan, pricingTerms, contentAddOn } from '../data/pricing';

const faqs = [
  {
    q: "Is the pricing really month-to-month?",
    a: `Yes. No annual contracts, no lock-in periods. We earn your business each month by showing you results. If you're not happy with what we're doing, you can cancel with ${pricingTerms.cancellationNoticeDays} days notice.`,
  },
  {
    q: "What's included in the setup fee?",
    a: `The ${growthPlan.setupLabel} covers work before your first month: a full audit of your digital presence, Google Business Profile optimization, review system setup, website onboarding, and your custom growth strategy.`,
  },
  {
    q: "How does the contact form map to this plan?",
    a: `Every core service — website, SEO, reviews, ads — is Growth (${growthPlan.monthlyLabel}). Social and video are not included; they're the separate content add-on (${contentAddOn.monthlyLabel}). Not sure? Book the free audit and we'll walk you through it.`,
  },
  {
    q: "Is social media included in Growth?",
    a: `No. Growth covers website, Google visibility, reviews, and ads. Social media and video production are a separate add-on at ${contentAddOn.monthlyLabel}, delivered by Jayden Aj through Forge's content team — the same engine behind Crab Boil's growth. You can run TRG without it, or add it when you're ready for short-form content.`,
  },
];

const pillars = [
  {
    title: "Google Visibility",
    body: "Optimized Google Business Profile and local search signals — the foundation of restaurant discovery in the GTA.",
  },
  {
    title: "Review Management",
    body: "Systems to generate, monitor, and respond to reviews across Google, Yelp, and TripAdvisor — the trust layer that converts searches into visits.",
  },
  {
    title: "Monthly Reporting",
    body: "Clear, jargon-free reports every month: how many people found you, what they did, and what we're doing next. No black boxes.",
  },
];
---

<BaseLayout
  title="Pricing — Simple, Transparent Restaurant Marketing | Toronto Restaurant Growth"
  description="No hidden fees. No long contracts. One plan: Growth at $997/mo plus $4,997 setup. Social and video available as a separate add-on."
>

  <main>

    <PageIntro
      eyebrow="Month-to-month · No contracts"
      title="Simple, Transparent Pricing"
      description="No hidden fees. No long contracts. One plan for full-service restaurant marketing."
    >
      <p class="mt-4 text-center text-base font-semibold text-accent">Pause or cancel anytime.</p>
    </PageIntro>

    <section class="bg-white px-6 py-20 sm:py-24 lg:px-8">
      <div class="mx-auto max-w-lg">
        <div class="relative rounded-3xl border-2 border-accent bg-white p-8 shadow-lg sm:p-10">
          <p class="text-sm font-semibold uppercase tracking-widest text-accent">Core plan</p>
          <h2 class="mt-2 font-heading text-3xl text-ink">{growthPlan.name}</h2>

          <p class="mt-5 flex items-baseline gap-x-2">
            <span class="font-heading text-5xl text-ink">$997</span>
            <span class="text-base text-ink-muted">/month</span>
          </p>
          <p class="mt-2 text-sm text-ink-muted">{growthPlan.setupLabel}</p>

          <p class="mt-6 text-base leading-7 text-ink-muted">
            {growthPlan.description}
          </p>

          <ul role="list" class="mt-8 space-y-3 text-sm leading-6 text-ink sm:mt-10">
            {growthPlan.features.map((feature) => (
              <li class="flex gap-x-3">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="h-5 w-5 flex-none text-accent">
                  <path d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" fill-rule="evenodd" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <a href="/contact/" class="btn-cta mt-8 w-full sm:mt-10">
            {growthPlan.cta}
          </a>
        </div>

        <p class="mt-8 text-center text-sm leading-relaxed text-ink-muted">
          Setup covers audit, GBP optimization, review systems, website onboarding, and your growth strategy.
          Grand opening campaigns are quoted separately —
          <a href="/services/grand-opening-marketing/" class="font-semibold text-cta no-underline hover:text-cta-hover">grand opening marketing</a>.
        </p>
      </div>
    </section>

    <!-- Social add-on -->
    <section class="border-t border-stone-border bg-surface px-6 py-20 sm:py-24 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-bold uppercase tracking-[0.15em] text-[#E85D04]">Optional add-on</p>
          <h2 class="mt-3 font-heading text-3xl text-[#1A1A1A] sm:text-4xl">{contentAddOn.name}</h2>
          <p class="mt-4 text-base leading-relaxed text-[#555555]">{contentAddOn.description}</p>
          <p class="mt-2 text-sm text-[#888888]">{contentAddOn.provider} · {contentAddOn.note}</p>
        </div>

        <div class="mt-14 grid grid-cols-1 items-start gap-10 lg:grid-cols-2">
          <ul role="list" class="space-y-3 text-sm leading-6 text-[#333333]">
            {contentAddOn.features.map((feature) => (
              <li class="flex gap-x-3 border-b border-[#f0f0ea] pb-3">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="h-5 w-5 flex-none text-[#E85D04]">
                  <path d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" fill-rule="evenodd" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <div class="rounded-2xl bg-[#F5F5F0] p-8 text-center ring-1 ring-[#E8E8E0]">
            <p class="font-heading text-4xl font-semibold text-[#E85D04]">{contentAddOn.monthlyLabel}</p>
            <p class="mt-3 text-sm text-[#666666]">Month-to-month · stacks with Growth</p>
            <a
              href="/services/social-media-management/"
              class="mt-6 block rounded-lg bg-[#1A1A1A] px-4 py-3.5 text-sm font-semibold text-white no-underline transition-colors hover:bg-[#333333]"
            >
              Learn about content
            </a>
            <a href="/contact/" class="mt-4 inline-block text-sm font-semibold text-[#B84500] no-underline hover:underline">
              Book a free audit →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Pillars -->
    <section class="bg-white px-6 py-20 sm:py-24 lg:px-8">
      <div class="mx-auto max-w-5xl text-center">
        <h2 class="font-heading text-3xl text-ink sm:text-4xl">
          One plan. Everything included. No hidden extras.
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-ink-muted">
          Growth includes the fundamentals restaurants need to compete on Google — no upsells, no tier games.
        </p>

        <div class="mt-14 grid grid-cols-1 gap-10 text-left sm:grid-cols-3">
          {pillars.map((pillar) => (
            <div class="rounded-xl border border-stone-border bg-cream p-8">
              <h3 class="font-heading text-lg text-ink">{pillar.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-muted">{pillar.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-surface px-6 py-20 sm:py-24 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <div class="text-center">
          <h2 class="font-heading text-3xl text-[#1A1A1A] sm:text-4xl">Pricing Questions</h2>
          <p class="mt-4 text-base text-[#555555]">Straight answers about Growth, setup, and the content add-on.</p>
        </div>

        <dl class="mt-12 divide-y divide-[#E8E8E0]">
          {faqs.map((faq) => (
            <div class="py-6">
              <dt class="font-heading text-lg text-[#1A1A1A]">{faq.q}</dt>
              <dd class="mt-3 text-sm leading-relaxed text-[#555555]">{faq.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-cta px-6 py-20 text-center sm:py-24">
      <div class="mx-auto max-w-2xl">
        <h2 class="font-heading text-3xl leading-tight text-white sm:text-4xl">
          Not sure if Growth is right for you?
        </h2>
        <p class="mx-auto mt-5 max-w-lg text-base leading-relaxed text-white/85">
          Start with a free Google Audit. We'll look at your current visibility and tell you exactly what level of support your restaurant needs. No commitment.
        </p>
        <a
          href="/contact/"
          class="mt-8 inline-flex items-center gap-2 rounded-lg bg-white px-8 py-4 text-base font-semibold text-[#E85D04] no-underline transition-colors hover:bg-[#F5F5F0]"
        >
          Book a Free Google Audit
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <p class="mt-4 text-sm text-white/90">Pause or cancel anytime. No contracts. No pressure.</p>
      </div>
    </section>

  </main>
</BaseLayout>
