---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/PageIntro.astro';
import PageSection from '../components/PageSection.astro';
import TallyEmbed from '../components/TallyEmbed.astro';
import { ctaNav } from '../data/navigation';
import { contentAddOn, growthPlan, intakeToTier, tierById } from '../data/pricing';
import {
  auditPrefillFromSearchParams,
  getAuditEmbedUrl,
  trgContactEmail,
} from '../data/tally';

const trustItems = [
  '100% Free — No Credit Card',
  '15 Minutes Max',
  'Restaurant-Specific Insights',
  'No Sales Pressure',
];

const auditIncludes = [
  'Where your restaurant ranks on Google Maps for your cuisine and neighbourhood',
  "What's missing from your Google Business Profile (most have 3–5 critical gaps)",
  'One thing you can fix this week to get more views — at no cost',
];

const prefill = auditPrefillFromSearchParams(Astro.url.searchParams);
const embedUrl = getAuditEmbedUrl(import.meta.env, prefill);

const afterSteps = [
  {
    step: '1',
    title: 'We review your digital presence',
    body: "Before the call, we audit your Google Business Profile, your website's SEO, your review velocity, and how you show up in local search.",
  },
  {
    step: '2',
    title: '15-minute call, no fluff',
    body: "We walk you through what's working, what's costing you customers, and the highest-leverage fixes — whether you hire us or not.",
  },
  {
    step: '3',
    title: 'A proposal if it makes sense',
    body: "If TRG is a fit, we'll share a specific proposal. If not, we'll tell you that too.",
  },
  {
    step: '4',
    title: 'Month-to-month if you proceed',
    body: 'No long-term contracts. We earn your business each month as results compound.',
  },
];

const faqs = [
  {
    q: 'Is the audit really free?',
    a: "Yes. No charge, no credit card, and no obligation. Most owners leave with actionable information they didn't have before.",
  },
  {
    q: 'What exactly do you audit?',
    a: 'Your Google Business Profile, basic website SEO health, and review signals — how you look to a customer searching on Google right now.',
  },
  {
    q: 'How long does the call take?',
    a: 'About 15 minutes. We respect your time — diagnosis, not a sales deck.',
  },
  {
    q: 'Do you work with chains or only independents?',
    a: 'Independent restaurants and small regional groups (2–5 locations). We do not work with national franchises.',
  },
  {
    q: 'What cities do you cover?',
    a: 'The Greater Toronto Area: Toronto, Mississauga, Brampton, Scarborough, Etobicoke, North York, Markham, Vaughan, Hamilton, and nearby municipalities.',
  },
];
---

<BaseLayout
  title="Book a Free Google Audit — Toronto Restaurant Growth"
  description="Get a free 15-minute review of your Google Business Profile, website, and reviews. We'll tell you exactly what's costing you customers. No pitch."
>
  <main>
    <PageIntro
      eyebrow="Free consultation"
      title="Your Free Google Audit — No Sales Pitch"
      description="We'll look at your Google Business Profile, your website, and your reviews — and tell you exactly what's costing you customers. 15 minutes. No pitch."
    >
      <ul class="mx-auto mt-8 max-w-xl space-y-3 text-left text-sm text-ink-muted">
        {auditIncludes.map((item) => (
          <li class="flex gap-3">
            <span class="mt-0.5 text-accent">✓</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <p class="mt-6 text-center text-sm font-medium text-ink">This is not a pitch. It's a diagnosis.</p>
    </PageIntro>

    <section class="border-y border-stone-border bg-surface py-5">
      <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-center gap-x-8 gap-y-3 px-4 sm:px-6">
        {trustItems.map((item) => (
          <div class="flex items-center gap-2 text-sm font-semibold text-ink">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-accent text-xs text-white">✓</span>
            {item}
          </div>
        ))}
      </div>
    </section>

    <section class="bg-white py-16 lg:py-24">
      <div class="mx-auto grid max-w-7xl grid-cols-1 gap-12 px-4 sm:px-6 lg:grid-cols-[1fr_380px] lg:gap-16 lg:px-8">
        <div>
          <h2 class="font-heading text-3xl text-ink sm:text-4xl">Tell us about your restaurant</h2>
          <p class="mt-4 text-base leading-relaxed text-ink-muted">
            Fill out the form below and we'll be in touch within one business day to schedule your free audit.
          </p>

          <div class="mt-10">
            <TallyEmbed embedUrl={embedUrl} title="Book a Free Google Audit" minHeight="720px" />
          </div>

          <details class="mt-10 rounded-xl border border-stone-border bg-surface p-6">
            <summary class="cursor-pointer font-heading text-lg text-ink">How service selections map to plans</summary>
            <p class="mt-4 text-sm leading-relaxed text-ink-muted">
              Pick what you need help with — we'll recommend the right fit on the audit call. Full details on our{' '}
              <a href="/pricing/" class="font-semibold text-cta no-underline hover:text-cta-hover">pricing page</a>.
            </p>
            <ul class="mt-4 space-y-3 border-t border-stone-border pt-4">
              {intakeToTier.map((row) => (
                <li class="text-sm leading-relaxed text-ink-muted">
                  <strong class="text-ink">{row.option}</strong>
                  <span class="mt-1 block">{row.note}</span>
                  {row.addOn === 'content' ? (
                    <span class="mt-1 block text-xs">
                      Add-on: {contentAddOn.name} ({contentAddOn.monthlyLabel}).
                    </span>
                  ) : row.tierId ? (
                    <span class="mt-1 block text-xs">
                      Included in {tierById(row.tierId).name} ({tierById(row.tierId).monthlyLabel}).
                    </span>
                  ) : null}
                </li>
              ))}
            </ul>
          </details>
        </div>

        <aside class="lg:sticky lg:top-24 lg:self-start">
          <div class="trg-card mb-6">
            <h3 class="font-heading text-lg text-ink">The plan</h3>
            <p class="mt-3 text-sm text-ink-muted">
              <strong class="text-ink">{growthPlan.name}</strong> — {growthPlan.monthlyLabel}
            </p>
            <p class="mt-1 text-sm text-ink-muted">{growthPlan.setupLabel}</p>
            <a href="/pricing/" class="mt-4 inline-flex text-sm font-semibold text-cta no-underline hover:text-cta-hover">
              View full pricing →
            </a>
          </div>

          <div class="trg-card mb-6 border-accent/20 bg-surface">
            <h3 class="font-heading text-lg text-ink">Content add-on</h3>
            <p class="mt-2 text-sm text-ink-muted">Social + video through Jayden Aj — not included in Growth.</p>
            <p class="mt-3 font-heading text-lg text-accent">{contentAddOn.monthlyLabel}</p>
          </div>

          <div class="trg-card mb-6 bg-surface">
            <h3 class="font-heading text-lg text-ink">Prefer email?</h3>
            <p class="mt-3 text-sm text-ink-muted">Response within one business day.</p>
            <a
              href={`mailto:${trgContactEmail}`}
              class="mt-3 inline-block text-sm font-semibold text-ink no-underline hover:text-cta"
            >
              {trgContactEmail}
            </a>
            <p class="mt-4 text-xs text-ink-muted">Service area: Greater Toronto Area</p>
          </div>

          <div class="trg-card">
            <h3 class="font-heading text-lg text-ink">Follow our work</h3>
            <div class="mt-4 flex flex-col gap-2">
              <a href="https://tiktok.com/@torontorestaurantgrowth" class="trg-link-card text-sm" target="_blank" rel="noopener">
                TikTok · @torontorestaurantgrowth
              </a>
              <a href="https://instagram.com/torontorestaurantgrowth" class="trg-link-card text-sm" target="_blank" rel="noopener">
                Instagram · @torontorestaurantgrowth
              </a>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <PageSection tone="surface" width="narrow" title="What happens after you book">
      <div class="space-y-8">
        {afterSteps.map((item) => (
          <div class="flex gap-5">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-cta font-heading text-lg text-white">
              {item.step}
            </div>
            <div>
              <h3 class="font-heading text-xl text-ink">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-muted">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </PageSection>

    <PageSection width="narrow" title="Frequently asked questions">
      <div class="divide-y divide-stone-border">
        {faqs.map((item) => (
          <div class="py-8 first:pt-0 last:pb-0">
            <h3 class="font-heading text-xl text-ink">{item.q}</h3>
            <p class="mt-3 text-base leading-relaxed text-ink-muted">{item.a}</p>
          </div>
        ))}
      </div>
    </PageSection>
  </main>
</BaseLayout>
