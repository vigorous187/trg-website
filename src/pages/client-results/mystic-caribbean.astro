---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import PageCta from '../../components/PageCta.astro';
import SeoScoreStrip from '../../components/SeoScoreStrip.astro';
import SeoRankingsTable from '../../components/SeoRankingsTable.astro';
import { mysticSeoReport } from '../../data/mystic-seo-report';

const report = mysticSeoReport;
---

<BaseLayout
  title="Mystic Caribbean SEO Results — Toronto Restaurant Growth"
  description="Live Google rankings for Mystic Caribbean Resto & Bar in Brampton. SEO score 32→73, 15 keywords in the top 10, #1 for Kennedy Rd restaurant searches."
>
  <main>
    <PageIntro
      eyebrow="Client SEO results"
      title="Mystic Caribbean — Google Rankings Report"
      description={`Tracked local SEO for ${report.clientName} in ${report.location}. Updated ${report.reportDate}. These are the same metrics TRG uses to prove ROI for restaurant clients.`}
      ctaLabel="Book a Free Google Audit"
      ctaHref="/contact/"
    />

    <section class="border-y border-stone-border bg-surface py-10 sm:py-12">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <SeoScoreStrip baseline={report.baseline} current={report.current} />
      </div>
    </section>

    <section class="py-16 lg:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <h2 class="font-heading text-3xl text-ink">Keyword rankings</h2>
            <p class="mt-2 max-w-2xl text-sm leading-relaxed text-ink-muted">
              Restaurant-only SERP scope for {report.domain}. Rank 101 means not in the top 100 — hidden from this table.
            </p>
          </div>
          <a
            href={report.dashboardUrl}
            class="inline-flex text-sm font-semibold text-cta no-underline hover:text-cta-hover"
            target="_blank"
            rel="noopener"
          >
            Full dashboard (client login) →
          </a>
        </div>

        <div class="mt-8">
          <SeoRankingsTable keywords={report.keywords} />
        </div>
      </div>
    </section>

    <section class="border-y border-stone-border bg-white py-16 lg:py-20">
      <div class="mx-auto grid max-w-6xl gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
        <div>
          <h2 class="font-heading text-2xl text-ink">Before TRG + Forge rebuild</h2>
          <p class="mt-3 text-sm leading-relaxed text-ink-muted">
            {report.baseline.label} ({report.baseline.date}): SEO score {report.baseline.total}/100. Discovery was mostly Maps and delivery apps — no competitive organic rankings.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-ink-muted">
            {report.baseline.issues.map((issue) => (
              <li class="flex gap-2">
                <span class="text-accent">×</span>
                <span>{issue}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="font-heading text-2xl text-ink">Technical foundation now</h2>
          <p class="mt-3 text-sm leading-relaxed text-ink-muted">
            Technical score maxed at {report.current.technical}/50 after the Forge site migration and schema rollout.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-ink-muted">
            {report.current.technicalChecks.map((check) => (
              <li class="flex gap-2">
                <span class="text-accent">✓</span>
                <span>{check}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <PageCta
      title="Want a report like this for your restaurant?"
      description="Every TRG engagement starts with a free Google audit. We'll show you where you rank today and what it would take to move."
    />
    <section class="pb-16 text-center">
      <a href="/case-studies/mystic-caribbean/" class="text-sm font-semibold text-cta no-underline hover:text-cta-hover">
        Read the Mystic case study →
      </a>
    </section>
  </main>
</BaseLayout>
