---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const lastUpdated = 'May 14, 2026';
---

<BaseLayout
  title="Terms of Use — Toronto Restaurant Growth"
  description="Terms governing use of the Toronto Restaurant Growth website and marketing consultations."
>
  <Navbar />

  <main style="padding-top: 80px; background: #F5F5F0; color: #1A1A1A;">
    <div style="max-width: 800px; margin: 0 auto; padding: 64px 24px 96px;">
      <h1 style="font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(28px, 4vw, 40px); font-weight: 400; margin-bottom: 12px;">
        Terms of Use
      </h1>
      <p style="font-size: 14px; color: #666; margin-bottom: 40px;">Last updated: {lastUpdated}</p>

      <div style="font-size: 16px; line-height: 1.75; color: #333;">
        <p style="margin-bottom: 20px;">
          These Terms of Use (“Terms”) govern your use of <strong>torontorestaurantgrowth.ca</strong> (the “Site”)
          operated by <strong>Toronto Restaurant Growth</strong>. By using the Site, you agree to these Terms.
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Services</h2>
        <p style="margin-bottom: 16px;">
          Content on the Site describes restaurant marketing services we may offer. Engagement terms, deliverables, and
          fees for paid work are set out in a separate proposal or agreement—not everything on the Site applies to every
          client or market.
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">No guarantee of results</h2>
        <p style="margin-bottom: 16px;">
          Marketing outcomes depend on many factors outside our control (for example competition, operations, and
          platform policies). Case studies or examples on the Site are illustrative, not promises of future performance.
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Limitation of liability</h2>
        <p style="margin-bottom: 16px;">
          To the fullest extent permitted by applicable law in Ontario and Canada, Toronto Restaurant Growth and its
          service providers and affiliates are not liable for indirect, incidental, special, consequential, or punitive
          damages arising from your use of the Site or reliance on its content.
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Acceptable use</h2>
        <p style="margin-bottom: 16px;">
          You agree not to misuse the Site, attempt unauthorized access, or use automated means to scrape or overload our
          systems beyond normal browsing.
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Privacy</h2>
        <p style="margin-bottom: 16px;">
          Our handling of personal information is described in our <a href="/privacy/" style="color: #B84500; font-weight: 600;">Privacy Policy</a>.
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Changes</h2>
        <p style="margin-bottom: 16px;">We may update these Terms from time to time. The “Last updated” date reflects the latest revision.</p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Contact</h2>
        <p>
          <a href="mailto:hello@torontorestaurantgrowth.ca" style="color: #B84500; font-weight: 600;">hello@torontorestaurantgrowth.ca</a>
        </p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
