---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const lastUpdated = 'May 14, 2026';
---

<BaseLayout
  title="Privacy Policy — Toronto Restaurant Growth"
  description="How Toronto Restaurant Growth collects, uses, and protects personal information when you use our website or book a consultation."
>
  <Navbar />

  <main style="padding-top: 80px; background: #F5F5F0; color: #1A1A1A;">
    <div style="max-width: 800px; margin: 0 auto; padding: 64px 24px 96px;">
      <h1 style="font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(28px, 4vw, 40px); font-weight: 400; margin-bottom: 12px;">
        Privacy Policy
      </h1>
      <p style="font-size: 14px; color: #666; margin-bottom: 40px;">Last updated: {lastUpdated}</p>

      <div style="font-size: 16px; line-height: 1.75; color: #333;">
        <p style="margin-bottom: 20px;">
          Toronto Restaurant Growth (“we”, “us”) respects your privacy. This policy explains how we handle personal
          information when you visit <strong>torontorestaurantgrowth.ca</strong>, email us, or submit information through
          our contact or audit forms.
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Who we are</h2>
        <p style="margin-bottom: 16px;">
          <strong>Toronto Restaurant Growth</strong><br />
          Ontario, Canada<br />
          Email: <a href="mailto:hello@torontorestaurantgrowth.ca" style="color: #B84500;">hello@torontorestaurantgrowth.ca</a>
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Information we collect</h2>
        <ul style="margin: 0 0 20px 1.1em; padding: 0;">
          <li style="margin-bottom: 10px;">
            <strong>Business and contact details</strong> — such as name, restaurant name, email, phone, and messages
            you provide when you book a consultation or use embedded forms on our site.
          </li>
          <li style="margin-bottom: 10px;">
            <strong>Technical data</strong> — such as IP address, browser type, and security telemetry collected by our
            hosting and security providers (for example Cloudflare) to operate and protect the site.
          </li>
        </ul>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">How we use information</h2>
        <ul style="margin: 0 0 20px 1.1em; padding: 0;">
          <li style="margin-bottom: 10px;">To respond to inquiries and deliver restaurant marketing services you request.</li>
          <li style="margin-bottom: 10px;">To operate, secure, and improve our website and lead workflows.</li>
          <li style="margin-bottom: 10px;">To meet legal or regulatory requirements where applicable.</li>
        </ul>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Third-party tools</h2>
        <p style="margin-bottom: 16px;">
          We may use trusted third-party form, scheduling, or analytics tools embedded on pages. Those providers process
          data under their own terms and privacy policies in addition to this policy. We do not sell your personal
          information.
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Cookies</h2>
        <p style="margin-bottom: 16px;">
          Our site may use cookies or similar technologies for security, performance, or embedded widgets. You can
          control cookies through your browser.
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Retention</h2>
        <p style="margin-bottom: 16px;">
          We retain personal information only as long as needed for the purposes above, including reasonable business and
          legal record-keeping.
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Your rights (Canada)</h2>
        <p style="margin-bottom: 16px;">
          Depending on your province, you may have rights to access or correct your personal information, subject to
          legal exceptions. Contact us at the email above to make a request.
        </p>

        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 22px; margin: 36px 0 12px;">Contact</h2>
        <p>
          <a href="mailto:hello@torontorestaurantgrowth.ca" style="color: #B84500; font-weight: 600;">hello@torontorestaurantgrowth.ca</a>
        </p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
