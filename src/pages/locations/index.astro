---
import BaseLayout from '../../layouts/BaseLayout.astro';

const locations = [
  {
    city: "Scarborough",
    region: "East Toronto",
    description: "High-density halal, Tamil, Caribbean, and South Asian restaurant scene. Some of the most competitive local dining markets in the GTA.",
    href: "/locations/scarborough/",
    highlights: ["Halal dining corridor", "Tamil & Caribbean cuisines", "Lawrence Ave E strip"],
  },
  {
    city: "Brampton",
    region: "Peel Region",
    description: "Canada's South Asian dining capital. Punjabi, Pakistani, and Desi-fusion restaurants in one of the GTA's fastest-growing communities.",
    href: "/locations/brampton/",
    highlights: ["South Asian cuisine hub", "Steeles Ave strip", "Rapid market growth"],
  },
  {
    city: "Mississauga",
    region: "Peel Region",
    description: "Diverse dining corridor along Hurontario and Dixie. A massive, underserved market for restaurant digital visibility.",
    href: "/locations/mississauga/",
    highlights: ["Hurontario corridor", "Square One area", "Multicultural dining"],
  },
  {
    city: "North York",
    region: "Toronto",
    description: "Yonge Street corridor and Finch food district. Dense population with high dining frequency and strong search volume.",
    href: "/locations/north-york/",
    highlights: ["Yonge & Finch district", "Korean & Chinese corridor", "High foot traffic"],
  },
  {
    city: "Etobicoke",
    region: "West Toronto",
    description: "Emerging restaurant strip with a loyal local clientele. Lower competition than central Toronto with strong neighborhood loyalty.",
    href: "/locations/etobicoke/",
    highlights: ["Emerging dining strip", "Loyal local base", "Lower competition"],
  },
  {
    city: "Hamilton",
    region: "Hamilton-Wentworth",
    description: "A growing culinary scene hungry for digital visibility. Hamilton's food culture is exploding and most restaurants are invisible online.",
    href: "/locations/hamilton/",
    highlights: ["James Street North", "Growing food scene", "Underserved market"],
  },
  {
    city: "Vaughan",
    region: "York Region",
    description: "Upscale dining meets a diverse community palate. Italian, Middle Eastern, and international cuisine in one of Ontario's wealthiest suburbs.",
    href: "/locations/vaughan/",
    highlights: ["VMC area growth", "Upscale dining market", "Italian & Middle Eastern"],
  },
  {
    city: "Markham",
    region: "York Region",
    description: "Vibrant East Asian and multicultural food hub. One of Canada's largest Chinese-Canadian communities with massive dining search volume.",
    href: "/locations/markham/",
    highlights: ["East Asian cuisine hub", "First Markham Place area", "High search volume"],
  },
];
---

<BaseLayout
  title="Restaurant Marketing GTA Locations | Toronto Restaurant Growth"
  description="Toronto Restaurant Growth serves restaurants across the GTA — Scarborough, Brampton, Mississauga, North York, Etobicoke, Hamilton, Vaughan, and Markham."
>

  <main style="padding-top: 80px;">

    <!-- HERO -->
    <section style="background: #1a1a1a; color: #fff; padding: 80px 24px; text-align: center;">
      <div style="max-width: 800px; margin: 0 auto;">
        <p style="text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.78rem; color: #E85D04; font-weight: 600; margin-bottom: 12px;">GTA Coverage</p>
        <h1 style="font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(2.2rem, 5vw, 3.2rem); color: #fff; margin-bottom: 20px; font-weight: 400;">
          Hyperlocal Restaurant Marketing Across the GTA
        </h1>
        <p style="font-size: 1.15rem; color: rgba(255,255,255,0.7); max-width: 620px; margin: 0 auto 32px; line-height: 1.7;">
          We don't do generic Toronto marketing. We know Brampton's halal dining scene, Scarborough's Tamil community, Markham's East Asian food culture. Every neighbourhood has its own dining dynamics — and we know them all.
        </p>
        <a href="/contact/" style="display: inline-block; background: #E85D04; color: #fff; padding: 14px 30px; text-decoration: none; font-weight: 600; font-size: 1rem; border-radius: 6px;">
          Book a Free Google Audit
        </a>
      </div>
    </section>

    <!-- LOCATIONS GRID -->
    <section style="background: #f5f5f0; padding: 80px 24px;">
      <div style="max-width: 1100px; margin: 0 auto;">
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px;">
          {locations.map(location => (
            <a
              href={location.href}
              style="background: #fff; border: 1px solid #e8e8e0; border-radius: 12px; padding: 32px; text-decoration: none; display: block;"
              onmouseover="this.style.borderColor='rgba(232,93,4,0.4)'"
              onmouseout="this.style.borderColor='#e8e8e0'"
            >
              <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E85D04" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                <span style="font-size: 0.78rem; color: #888; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em;">{location.region}</span>
              </div>
              <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: 1.5rem; color: #1a1a1a; margin-bottom: 12px; font-weight: 400;">
                {location.city}
              </h2>
              <p style="color: #555; font-size: 0.9rem; line-height: 1.6; margin-bottom: 20px;">
                {location.description}
              </p>
              <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px;">
                {location.highlights.map(h => (
                  <li style="font-size: 0.82rem; color: #666; display: flex; align-items: center; gap: 8px;">
                    <span style="color: #E85D04; font-weight: 700;">→</span>
                    {h}
                  </li>
                ))}
              </ul>
              <span style="color: #B84500; font-size: 0.9rem; font-weight: 600; display: inline-flex; align-items: center; gap: 4px;">
                See local services
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section style="background: #E85D04; color: #fff; padding: 80px 24px; text-align: center;">
      <div style="max-width: 700px; margin: 0 auto;">
        <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(1.8rem, 4vw, 2.6rem); color: #fff; margin-bottom: 20px; font-weight: 400;">
          Don't see your city? We still serve you.
        </h2>
        <p style="font-size: 1.1rem; color: rgba(255,255,255,0.85); max-width: 500px; margin: 0 auto 32px; line-height: 1.7;">
          If you're a restaurant anywhere in Ontario, we can help. Book a free audit and let's talk about your market.
        </p>
        <a href="/contact/" style="display: inline-block; background: #fff; color: #E85D04; padding: 14px 30px; text-decoration: none; font-weight: 700; font-size: 1rem; border-radius: 6px;">
          Book a Free Google Audit
        </a>
      </div>
    </section>

  </main>
</BaseLayout>
