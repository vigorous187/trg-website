---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClientLogo from '../components/ClientLogo.astro';
import { ctaNav } from '../data/navigation';
import { crabBoilProof, mysticProof, contentReachAddOn } from '../data/client-proof';

const clientSpotlights = [crabBoilProof, mysticProof];

const blogPosts = [
  {
    title: "How Toronto Restaurants Improve Google Maps Visibility",
    excerpt: "Google Maps is the number one discovery channel for local restaurants. Here's exactly how to claim your spot at the top.",
    slug: "toronto-restaurants-rank-google-maps",
    date: "March 15, 2026",
    category: "Google & SEO",
  },
  {
    title: "Why Your Restaurant's TikTok Isn't Growing (And How to Fix It)",
    excerpt: "Most restaurants post on TikTok and get nothing. The restaurants that go viral do one thing differently — and it's not what you think.",
    slug: "restaurant-tiktok-growth-strategy",
    date: "March 14, 2026",
    category: "Social Media",
  },
  {
    title: "The Complete Guide to Halal Restaurant Marketing in the GTA",
    excerpt: "Halal dining is one of the fastest-growing segments in Toronto. Here's how to reach your community effectively and build lasting loyalty.",
    slug: "halal-restaurant-marketing-gta",
    date: "February 28, 2026",
    category: "Niche Marketing",
  },
];

const locations = [
  { city: "Scarborough", hook: "High-density halal & South Asian restaurant scene", href: "/locations/scarborough/" },
  { city: "Brampton", hook: "One of the GTA's fastest-growing dining communities", href: "/locations/brampton/" },
  { city: "Mississauga", hook: "Diverse dining corridor along Hurontario & Dixie", href: "/locations/mississauga/" },
  { city: "North York", hook: "Yonge Street corridor and Finch food district", href: "/locations/north-york/" },
  { city: "Etobicoke", hook: "Emerging restaurant strip with loyal local clientele", href: "/locations/etobicoke/" },
  { city: "Hamilton", hook: "Growing culinary scene hungry for digital visibility", href: "/locations/hamilton/" },
  { city: "Vaughan", hook: "Upscale dining meets diverse community taste", href: "/locations/vaughan/" },
  { city: "Markham", hook: "Vibrant East Asian and multicultural food hub", href: "/locations/markham/" },
];

const services = [
  {
    title: "Restaurant Website Design",
    description: "Fast, mobile-first websites that turn visitors into reservations. Built for restaurants, not one-size-fits-all templates.",
    href: "/services/restaurant-website-design/",
  },
  {
    title: "Social Media Management",
    description: "Content that earns views, not just followers. Available as a separate add-on through Jayden Aj.",
    href: "/services/social-media-management/",
  },
  {
    title: "Google Maps & SEO",
    description: "Show up when hungry customers search nearby. We optimize your Google Business Profile and local search presence.",
    href: "/services/google-maps-seo/",
  },
  {
    title: "Review Management",
    description: "Respond to every review, protect your reputation, and turn happy customers into your best marketing.",
    href: "/services/review-management/",
    badge: "Most requested",
  },
  {
    title: "Grand Opening Marketing",
    description: "Launch with a lineup out the door. We run the full digital campaign — from buzz-building to opening day coverage.",
    href: "/services/grand-opening-marketing/",
  },
];

const contentReach = [...crabBoilProof.contentReach, ...contentReachAddOn];
---

<BaseLayout
  title="Restaurant Marketing Agency Toronto | Toronto Restaurant Growth"
  description="Restaurant marketing Toronto operators trust — a restaurant marketing agency for website, Google Maps, reviews, and ads that drive restaurant growth. Month-to-month. Social and video available as a separate add-on."
>
  <main>
    <!-- Studio split hero -->
    <section class="overflow-hidden bg-cream">
      <div class="mx-auto grid max-w-7xl grid-cols-1 gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:items-center lg:gap-16 lg:py-24 lg:px-8">
        <div>
          <p class="section-label mb-4">Toronto's Restaurant-Only Marketing Agency</p>
          <h1 class="font-heading text-4xl leading-tight text-ink sm:text-5xl lg:text-[3.25rem] lg:leading-[1.1]">
            More Covers.<br />
            Better Reviews.<br />
            <span class="text-accent">All From Google.</span>
          </h1>
          <p class="mt-4 max-w-xl text-lg font-medium leading-relaxed text-ink">
            Restaurant marketing agency in Toronto — Google Maps, reviews, websites, and ads for independent operators.
          </p>
          <p class="mt-4 max-w-xl text-lg leading-relaxed text-ink-muted">
            Toronto's only marketing agency built exclusively for independent restaurants. We handle your website, Google Maps, reviews, and ads — so you can focus on running your kitchen. Social and video content is available as a separate add-on through Jayden Aj.
          </p>
          <p class="mt-4 max-w-xl text-base leading-relaxed text-ink-muted">
            Whether you're opening a second location or filling slow weeknights, a restaurant marketing agency that only works with restaurants knows what actually moves covers in this city.
          </p>
          <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
            <a href={ctaNav.href} class="btn-cta">
              {ctaNav.label}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </a>
            <a href="#metrics-wall" class="btn-cta-outline">See Our Results</a>
          </div>
          <p class="mt-8 text-sm text-ink-muted">
            <strong class="text-ink">Built for Toronto's independent restaurants</strong> — Google-first growth systems for local operators
          </p>
        </div>

        <div class="relative lg:pl-4">
          <div class="aspect-[4/5] overflow-hidden rounded-2xl bg-surface shadow-xl ring-1 ring-stone-border sm:aspect-[5/4]">
            <img
              src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=1200&q=80"
              alt="Busy Toronto restaurant dining room"
              class="h-full w-full object-cover"
              width="1200"
              height="960"
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <div class="absolute -bottom-6 -left-4 hidden max-w-xs rounded-xl border border-stone-border bg-white p-5 shadow-lg sm:block lg:-left-8">
            <ClientLogo client="crabBoil" size="sm" loading="eager" />
            <p class="mt-3 font-heading text-2xl text-accent">5,000+</p>
            <p class="mt-1 text-sm text-ink-muted">Google reviews for Crab Boil · 4.8★ flagship locations</p>
            <a href="/case-studies/crab-boil/" class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-cta no-underline hover:text-cta-hover">
              Read case study
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission strip -->
    <section class="border-y border-stone-border bg-surface py-5">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <p class="text-center text-sm font-semibold text-ink sm:text-base">
          We only work with restaurants. Not gyms. Not dentists.
          <span class="font-heading italic text-accent"> Restaurants.</span>
        </p>
      </div>
    </section>

    <!-- Proof / metrics -->
    <section id="metrics-wall" class="bg-white py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl">
          <p class="section-label mb-3">Results</p>
          <h2 class="font-heading text-3xl text-ink sm:text-4xl">Business outcomes from active restaurant clients.</h2>
          <p class="mt-4 text-lg leading-relaxed text-ink-muted">
            Reviews, rankings, retainer growth, and local search wins — not vanity impressions. Two operators we're building with right now.
          </p>
        </div>

        <div class="mt-14 grid grid-cols-1 gap-8 lg:grid-cols-2">
          {clientSpotlights.map((client) => (
            <article class="rounded-2xl border border-stone-border bg-cream p-8 lg:p-10">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <span class="rounded-full bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-accent">
                  {client.tag}
                </span>
                <span class="text-xs font-medium uppercase tracking-wide text-ink-muted">{client.location}</span>
              </div>
              <ClientLogo client={client.logo} size="lg" class="mt-6" />

              <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
                {client.businessMetrics.map((stat) => (
                  <div class="rounded-lg border border-stone-border/80 bg-white px-4 py-4">
                    <p class="font-heading text-2xl text-accent">{stat.value}</p>
                    <p class="mt-1 text-xs font-semibold text-ink">{stat.label}</p>
                    <p class="mt-0.5 text-[11px] leading-snug text-ink-muted">{stat.sub}</p>
                  </div>
                ))}
              </div>

              <ul class="mt-8 space-y-2.5 text-sm leading-relaxed text-ink-muted">
                {client.outcomes.map((outcome) => (
                  <li class="flex gap-2">
                    <span class="text-accent" aria-hidden="true">✓</span>
                    <span>{outcome}</span>
                  </li>
                ))}
              </ul>

              <a href={client.href} class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-cta no-underline hover:text-cta-hover">
                {client.name === crabBoilProof.name ? "Read the Crab Boil case study" : "See our Google Maps & SEO work"}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </a>
            </article>
          ))}
        </div>

        <div class="mt-16 border-t border-stone-border pt-12">
          <div class="max-w-2xl">
            <p class="text-xs font-semibold uppercase tracking-widest text-ink-muted">Supporting · content reach (add-on)</p>
            <p class="mt-2 text-sm leading-relaxed text-ink-muted">
              Social and video through Jayden Aj compounds reach on top of Google — secondary to covers, calls, and bookings.
            </p>
          </div>
          <div class="mt-8 grid grid-cols-2 gap-4 lg:grid-cols-5">
            {contentReach.map((stat) => (
              <div class="rounded-lg border border-stone-border/80 bg-surface px-4 py-4">
                <p class="font-heading text-xl text-accent sm:text-2xl">{stat.value}</p>
                <p class="mt-1 text-xs font-medium text-ink">{stat.label}</p>
                <p class="mt-0.5 text-[11px] text-ink-muted">{stat.sub}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="bg-surface py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl">
          <p class="section-label mb-3">Services</p>
          <h2 class="font-heading text-3xl text-ink sm:text-4xl">
            Everything your restaurant needs.
            <span class="text-accent">Nothing you don't.</span>
          </h2>
          <p class="mt-4 text-lg text-ink-muted">
            One agency. One focus. Five services designed specifically for how restaurants grow.
          </p>
        </div>

        <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((service) => (
            <a
              href={service.href}
              class="group relative block rounded-xl border border-stone-border bg-white p-8 no-underline shadow-sm transition-shadow hover:shadow-md"
            >
              {'badge' in service && service.badge && (
                <span class="absolute right-6 top-6 rounded-full bg-accent/10 px-2.5 py-1 text-xs font-semibold uppercase tracking-wide text-accent">
                  {service.badge}
                </span>
              )}
              <h3 class="text-lg font-semibold text-ink group-hover:text-cta">{service.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-muted">{service.description}</p>
              <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-cta">
                Learn more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Halal niche -->
    <section class="bg-white py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="overflow-hidden rounded-2xl bg-halal-green p-10 text-white lg:p-16">
          <p class="text-xs font-semibold uppercase tracking-widest text-white/70">Halal-Certified Dining Community</p>
          <h2 class="mt-4 max-w-2xl font-heading text-3xl leading-tight sm:text-4xl">
            Serving the GTA's Halal Restaurant Community
          </h2>
          <p class="mt-6 max-w-2xl text-base leading-relaxed text-white/80">
            The Greater Toronto Area has one of the largest halal dining scenes in North America. We understand halal certification marketing, community-driven discovery, and the platforms your customers actually use. From Brampton to Scarborough, we help halal restaurants get found — and stay full.
          </p>
          <ul class="mt-8 space-y-3 text-sm text-white/85">
            <li class="flex gap-3"><span class="text-accent">✓</span> Halal-verified messaging in all content</li>
            <li class="flex gap-3"><span class="text-accent">✓</span> Community-aware social media strategy</li>
            <li class="flex gap-3"><span class="text-accent">✓</span> Google Business Profile optimized for halal search terms</li>
          </ul>
          <a
            href="/niche/halal-restaurant-marketing-toronto/"
            class="mt-8 inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-halal-green no-underline hover:bg-cream"
          >
            Learn About Halal Restaurant Marketing
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <p class="mt-6 text-sm text-white/70">
            <a href="/niche/seo-restaurantes-toronto/" class="text-white/90 underline hover:text-white">En español</a>
            <span class="mx-2" aria-hidden="true">·</span>
            <a href="/niche/seo-restaurants-toronto/" class="text-white/90 underline hover:text-white">En français</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Why this works -->
    <section class="bg-surface py-20 lg:py-28">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
        <p class="section-label mb-3">Why this works</p>
        <h2 class="font-heading text-3xl text-ink sm:text-4xl">Google first. Covers second. Content when you're ready.</h2>
        <p class="mt-6 text-base leading-relaxed text-ink-muted">
          Independent restaurants don't need vanity metrics on a homepage. They need more calls, direction requests, reservations, and reviews — the signals on a Google Business Profile that turn into full tables. We optimize GBP and local search first; social and video are a separate add-on when you want reach on top of a foundation that's already working.
        </p>
      </div>
    </section>

    <!-- Locations -->
    <section class="bg-surface py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-start">
          <div>
            <p class="section-label mb-3">Locations</p>
            <h2 class="font-heading text-3xl text-ink sm:text-4xl">Serving independent restaurants across the GTA</h2>
            <p class="mt-6 text-base leading-relaxed text-ink-muted">
              We know the neighbourhoods where your customers live. We know the Brampton halal strip. We know Scarborough's food court culture. We know what motivates a North York family to pick one restaurant over another on a Tuesday night. Local knowledge isn't a bonus — it's the foundation of everything we build.
            </p>
          </div>

          <div class="flex flex-wrap gap-2">
            {locations.map((location) => (
              <a
                href={location.href}
                class="rounded-full border border-stone-border bg-white px-4 py-2 text-sm font-medium text-ink no-underline transition-colors hover:border-accent hover:text-accent"
              >
                {location.city}
              </a>
            ))}
          </div>
        </div>

        <div class="mt-12 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {locations.map((location) => (
            <a
              href={location.href}
              class="group block rounded-xl border border-stone-border bg-white p-6 no-underline transition-colors hover:border-accent/40"
            >
              <h3 class="font-semibold text-ink group-hover:text-accent">{location.city}</h3>
              <p class="mt-2 text-xs leading-relaxed text-ink-muted">{location.hook}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="bg-white py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl">
          <p class="section-label mb-3">How it works</p>
          <h2 class="font-heading text-3xl text-ink sm:text-4xl">From invisible to fully booked</h2>
          <p class="mt-4 text-lg text-ink-muted">No long contracts. No agency runaround. Just a clear plan and the team to execute it.</p>
        </div>

        <div class="mt-14 grid grid-cols-1 gap-10 md:grid-cols-3">
          <div>
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-cta font-heading text-lg text-white">1</div>
            <h3 class="mt-5 text-xl font-semibold text-ink">Free Google Audit</h3>
            <p class="mt-3 leading-relaxed text-ink-muted">
              We audit your Google Business Profile, local search rankings, website, and competitor landscape — free, no strings attached.
            </p>
          </div>
          <div>
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-cta font-heading text-lg text-white">2</div>
            <h3 class="mt-5 text-xl font-semibold text-ink">Custom Growth Plan</h3>
            <p class="mt-3 leading-relaxed text-ink-muted">
              We build a tailored strategy based on your restaurant, your neighbourhood, and your goals. No templates. No generic playbooks.
            </p>
          </div>
          <div>
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-cta font-heading text-lg text-white">3</div>
            <h3 class="mt-5 text-xl font-semibold text-ink">We Execute</h3>
            <p class="mt-3 leading-relaxed text-ink-muted">
              Our team handles your website, Google optimization, and reviews. Add social and video through Jayden when you're ready.
            </p>
          </div>
        </div>

        <div class="mt-12">
          <a href={ctaNav.href} class="btn-cta">
            {ctaNav.label}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Blog -->
    <section class="bg-surface py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="section-label mb-3">Insights</p>
            <h2 class="font-heading text-3xl text-ink sm:text-4xl">Restaurant growth insights, no fluff.</h2>
            <p class="mt-2 text-ink-muted">Restaurant marketing insights for Toronto operators.</p>
          </div>
          <a href="/blog/" class="inline-flex items-center gap-2 text-sm font-semibold text-cta no-underline hover:text-cta-hover">
            Read the blog
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>

        <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
          {blogPosts.map((post) => (
            <a
              href={`/blog/${post.slug}/`}
              class="group block overflow-hidden rounded-xl border border-stone-border bg-white no-underline shadow-sm transition-shadow hover:shadow-md"
            >
              <div class="h-40 bg-gradient-to-br from-accent/10 to-surface"></div>
              <div class="p-6">
                <div class="flex items-center gap-3 text-xs">
                  <span class="font-semibold uppercase tracking-wider text-accent">{post.category}</span>
                  <span class="text-ink-muted">{post.date}</span>
                </div>
                <h3 class="mt-3 text-lg font-semibold leading-snug text-ink group-hover:text-cta">{post.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-ink-muted">{post.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-cta py-20 lg:py-24">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="font-heading text-3xl leading-tight text-white sm:text-4xl">
          Your restaurant's Google profile is leaving money on the table.
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-white/90">
          Book a free 30-minute Google Audit. We'll show you exactly what's costing you customers — and how to fix it.
        </p>
        <a
          href={ctaNav.href}
          class="mt-10 inline-flex items-center gap-2 rounded-lg bg-white px-10 py-4 text-base font-bold text-cta no-underline hover:bg-cream"
        >
          {ctaNav.label}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <p class="mt-6 text-sm italic text-white/80">No pitch. No pressure. Just a clear look at where you stand.</p>
      </div>
    </section>
  </main>
</BaseLayout>
