---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) =>
    new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime(),
);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-CA', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Blog | Toronto Restaurant Growth"
  description="Restaurant marketing insights for Toronto and GTA independent restaurant owners. Google SEO, reviews, social media — practical advice that drives covers."
>
  <Navbar />

  <main>
    <section style="background: #1A1A1A; padding: 100px 24px 72px; text-align: center;">
      <h1
        style="font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 400; color: #fff; line-height: 1.15; max-width: 640px; margin: 0 auto 16px;"
      >
        From the Blog
      </h1>
      <p style="font-size: 17px; color: rgba(255,255,255,0.6); max-width: 520px; margin: 0 auto; line-height: 1.7;">
        Practical restaurant marketing advice for Toronto and GTA operators — no fluff, no generic tips.
      </p>
    </section>

    <section style="background: #F5F5F0; padding: 72px 24px 96px;">
      <div style="max-width: 800px; margin: 0 auto;">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}
            style="display: block; background: #fff; border: 1px solid #E8E8E0; border-radius: 16px; padding: 40px 44px; margin-bottom: 24px; text-decoration: none;"
          >
            <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 14px; flex-wrap: wrap;">
              <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #E85D04;">{post.data.category}</span>
              <span style="width: 3px; height: 3px; border-radius: 50%; background: #ccc; display: inline-block;"></span>
              <span style="font-size: 13px; color: #666;">{formatDate(post.data.publishDate)}</span>
              {post.data.readTime && (
                <>
                  <span style="width: 3px; height: 3px; border-radius: 50%; background: #999; display: inline-block;"></span>
                  <span style="font-size: 13px; color: #666;">{post.data.readTime}</span>
                </>
              )}
            </div>
            <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(20px, 3vw, 26px); font-weight: 400; color: #1A1A1A; line-height: 1.3; margin: 0 0 12px;">
              {post.data.title}
            </h2>
            <p style="font-size: 15px; color: #555; line-height: 1.72; margin: 0;">
              {post.data.description}
            </p>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
