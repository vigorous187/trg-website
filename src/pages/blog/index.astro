---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) =>
    new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime(),
);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-CA', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Blog | Toronto Restaurant Growth"
  description="Restaurant marketing insights for Toronto and GTA independent restaurant owners. Google SEO, reviews, social media — practical advice that drives covers."
>
  <main>
    <PageIntro title="From the Blog" description="Practical restaurant marketing advice for Toronto and GTA operators — no fluff, no generic tips." />

    <section class="bg-surface py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}
            class="mb-6 block rounded-xl border border-stone-border bg-white p-8 no-underline shadow-sm transition-shadow hover:shadow-md"
          >
            <div class="mb-3 flex flex-wrap items-center gap-3 text-xs">
              <span class="font-semibold uppercase tracking-wider text-accent">{post.data.category}</span>
              <span class="text-ink-muted">{formatDate(post.data.publishDate)}</span>
              {post.data.readTime && <span class="text-ink-muted">{post.data.readTime}</span>}
            </div>
            <h2 class="font-heading text-xl text-ink">{post.data.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-ink-muted">{post.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
