---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const posts = [
  {
    title: "Why Your Toronto Restaurant Isn't Showing Up on Google (And How to Fix It)",
    excerpt: "If your restaurant doesn't show up in Google search results or on Google Maps, here are the most common reasons — and 7 actionable fixes you can implement today.",
    slug: "why-your-restaurant-not-showing-on-google",
    date: "April 6, 2026",
    category: "Google & SEO",
    readTime: "8 min read",
  },
];
---

<BaseLayout
  title="Blog | Toronto Restaurant Growth"
  description="Restaurant marketing insights for Toronto and GTA independent restaurant owners. Google SEO, reviews, social media — practical advice that drives covers."
>
  <Navbar />

  <main>

    <!-- Hero -->
    <section style="background: #1A1A1A; padding: 100px 24px 72px; text-align: center;">
      <div style="display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 999px; padding: 6px 16px; margin-bottom: 24px;">
        <span style="width: 8px; height: 8px; border-radius: 50%; background: #E85D04; display: inline-block;"></span>
        <span style="color: rgba(255,255,255,0.7); font-size: 13px; font-weight: 500;">Restaurant Marketing Insights</span>
      </div>
      <h1
        style="font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 400; color: #fff; line-height: 1.15; max-width: 640px; margin: 0 auto 16px;"
      >
        From the Blog
      </h1>
      <p style="font-size: 17px; color: rgba(255,255,255,0.6); max-width: 520px; margin: 0 auto; line-height: 1.7;">
        Practical restaurant marketing advice for Toronto and GTA operators — no fluff, no generic tips.
      </p>
    </section>

    <!-- Post List -->
    <section style="background: #F5F5F0; padding: 72px 24px 96px;">
      <div style="max-width: 800px; margin: 0 auto;">

        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}/`}
            style="display: block; background: #fff; border: 1px solid #E8E8E0; border-radius: 16px; padding: 40px 44px; margin-bottom: 24px; text-decoration: none; transition: border-color 0.2s, box-shadow 0.2s;"
            onmouseover="this.style.borderColor='rgba(232,93,4,0.4)'; this.style.boxShadow='0 4px 24px rgba(0,0,0,0.08)';"
            onmouseout="this.style.borderColor='#E8E8E0'; this.style.boxShadow='none';"
          >
            <!-- Meta row -->
            <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 14px; flex-wrap: wrap;">
              <span style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #E85D04;">{post.category}</span>
              <span style="width: 3px; height: 3px; border-radius: 50%; background: #ccc; display: inline-block;"></span>
              <span style="font-size: 13px; color: #666;">{post.date}</span>
              <span style="width: 3px; height: 3px; border-radius: 50%; background: #999; display: inline-block;"></span>
              <span style="font-size: 13px; color: #666;">{post.readTime}</span>
            </div>

            <!-- Title -->
            <h2 style="font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(20px, 3vw, 26px); font-weight: 400; color: #1A1A1A; line-height: 1.3; margin: 0 0 12px;">
              {post.title}
            </h2>

            <!-- Excerpt -->
            <p style="font-size: 15px; color: #555; line-height: 1.72; margin: 0 0 20px;">
              {post.excerpt}
            </p>

            <!-- Read link -->
            <span style="display: inline-flex; align-items: center; gap: 6px; color: #E85D04; font-size: 14px; font-weight: 600;">
              Read the article
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </a>
        ))}

      </div>
    </section>

    <!-- Bottom CTA -->
    <section style="background: #1A1A1A; padding: 72px 24px; text-align: center;">
      <h2
        style="font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(1.5rem, 3.5vw, 2.5rem); font-weight: 400; color: #fff; margin: 0 0 12px; line-height: 1.2;"
      >
        Want us to audit your restaurant's Google presence?
      </h2>
      <p style="color: rgba(255,255,255,0.6); font-size: 16px; margin: 0 0 28px; line-height: 1.7;">
        15 minutes. Free. We'll show you exactly where you're losing customers.
      </p>
      <a
        href="/contact/"
        style="display: inline-flex; align-items: center; gap: 8px; background: #E85D04; color: #fff; font-weight: 700; font-size: 15px; padding: 14px 32px; border-radius: 6px; text-decoration: none;"
      >
        Book a Free Audit
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </section>

  </main>

  <Footer />
</BaseLayout>
