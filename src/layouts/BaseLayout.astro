---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { siteName, trgLogo } from '../data/branding';

export interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title = "Toronto Restaurant Growth | Restaurant Marketing Agency",
  description = "Toronto's only marketing agency built exclusively for independent restaurants. We handle your website, social media, Google Maps, and reviews — so you can focus on running your kitchen.",
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  ogImage = "/og-default.png",
  schema,
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site?.href?.replace(/\/$/, '') || 'https://torontorestaurantgrowth.ca';
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const logoUrl = `${siteUrl}${trgLogo.mark}`;
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [{
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: siteName,
  url: siteUrl,
  logo: logoUrl,
  image: logoUrl,
  description,
  areaServed: { '@type': 'City', name: 'Toronto' },
  serviceType: 'Restaurant Marketing',
}];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en-CA" href={canonicalURL} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD Schema -->
    {schemas.map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Self-hosted fonts -->
    <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/dm-serif-display-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon — circular TRG mark -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body class="m-0 bg-cream p-0 font-body text-ink antialiased">
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>
